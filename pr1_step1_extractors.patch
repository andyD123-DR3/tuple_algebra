+# experiments/fix_calibration/CMakeLists.txt
+#
+# Build system for the FIX parser optimisation experiment programs.
+# Six self-contained programs (A–F) plus unit and integration tests.
+#
+# Options:
+#   EXPERIMENT_MOCK   Build with mock measurement (no RDTSC needed)
+#
+# Usage:
+#   cmake -B build -DCTDP_BUILD_EXPERIMENTS=ON -DEXPERIMENT_MOCK=ON
+#   cmake --build build
+#   ctest --test-dir build -R "test_extractors|test_beam_search|test_mock_pipeline"
+
+option(EXPERIMENT_MOCK
+    "Use deterministic mock measurement instead of real RDTSC" OFF)
+
+# ── Common interface library ──────────────────────────────────
+add_library(exp_common INTERFACE)
+target_include_directories(exp_common INTERFACE
+    ${CMAKE_CURRENT_SOURCE_DIR}/common
+    ${CMAKE_CURRENT_SOURCE_DIR}/generated)
+target_link_libraries(exp_common INTERFACE ctdp_all)
+
+if(EXPERIMENT_MOCK)
+    target_compile_definitions(exp_common INTERFACE EXPERIMENT_MOCK)
+endif()
+
+# ── Tests ─────────────────────────────────────────────────────
+# GTest is already available via FetchContent in the parent tests/ dir.
+# If experiments are built without the main tests, fetch it here too.
+if(NOT TARGET GTest::gtest_main)
+    include(FetchContent)
+    FetchContent_Declare(
+        googletest
+        GIT_REPOSITORY https://github.com/google/googletest.git
+        GIT_TAG        v1.15.2)
+    set(gtest_force_shared_crt ON CACHE BOOL "" FORCE)
+    FetchContent_MakeAvailable(googletest)
+endif()
+
+include(GoogleTest)
+
+# Unit tests
+add_executable(test_extractors tests/test_extractors.cpp)
+target_link_libraries(test_extractors PRIVATE exp_common GTest::gtest GTest::gtest_main)
+gtest_discover_tests(test_extractors)
